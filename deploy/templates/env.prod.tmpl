# Generated on the VPS by deploy bootstrap from inventory.yaml.
# .env is listed in .gitignore — never commit it.

# Production (docker-compose.prod.yml + Caddy TLS)
DOMAIN={{ .Domain }}
IMAGE_TAG={{ .ImageTag }}
TLS_CADDY_DATA_DIR={{ .TLSCaddyDataDir }}
TLS_CADDY_CONFIG_DIR={{ .TLSCaddyConfigDir }}

# T-Invest API token for bond enrich / screener (system-wide, read-only is enough)
TINKOFF_TOKEN={{ .TinkoffToken }}

# Trading tokens — LOCAL / AUTH_DISABLED only (fallback when user has no DB credentials).
# In multi-tenant prod users store encrypted tokens via /account.
T_TRADING_TOKEN_SANDBOX={{ .TTradingTokenSandbox }}
T_TRADING_TOKEN_PRODUCTION={{ .TTradingTokenProduction }}

# Master key for envelope-encrypting per-user broker tokens (required when AUTH_DISABLED=false).
# Keep separately from DB backups.
BROKER_KEK={{ .BrokerKEK }}

# Screener UI defaults
MAX_DAYS={{ .MaxDays }}
MIN_VOLUME_RUB={{ .MinVolumeRub }}

# Database (SQLite default locally; Postgres in production)
# DATABASE_URL=sqlite+aiosqlite:///./cache/instrumenta.db
DATABASE_URL=postgres://instrumenta:{{ .PostgresPassword }}@db:5432/instrumenta?sslmode=disable
POSTGRES_PASSWORD={{ .PostgresPassword }}

# Optional cache directory override
# CACHE_DIR=./cache

# API logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL={{ .LogLevel }}

# Auth (Telegram OIDC + JWT)
# AUTH_DISABLED=true disables OIDC; middleware injects DEV_TELEGRAM_ID as owner.
AUTH_DISABLED={{ .AuthDisabled }}
AUTH_SECRET={{ .AuthSecret }}
PUBLIC_APP_URL=https://{{ .Domain }}
TELEGRAM_OIDC_CLIENT_ID={{ .TelegramOIDCClientID }}
TELEGRAM_OIDC_CLIENT_SECRET={{ .TelegramOIDCClientSecret }}
TELEGRAM_OIDC_REDIRECT_URI=https://{{ .Domain }}/api/v1/auth/telegram/callback
DEV_TELEGRAM_ID={{ .DevTelegramID }}

# Notifier worker + Redis bus
REDIS_URL=redis://redis:6379/0
NOTIFIER_SCAN_INTERVAL_SEC={{ .NotifierScanIntervalSec }}
TELEGRAM_BOT_TOKEN={{ .TelegramBotToken }}
# Optional; otherwise resolved via Telegram getMe at API startup
TELEGRAM_BOT_USERNAME={{ .TelegramBotUsername }}
NOTIFIER_LEDGER_PATH=/app/cache/notifier_ledger.db

# Billing / YooKassa (optional — checkout disabled when shop credentials empty)
YOOKASSA_SHOP_ID={{ .YooKassaShopID }}
YOOKASSA_SECRET_KEY={{ .YooKassaSecretKey }}
COMPLIMENTARY_TELEGRAM_IDS={{ .ComplimentaryTelegramIDs }}
