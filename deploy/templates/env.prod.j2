# Generated on the VPS by pyinfra from host data.
# .env is listed in .gitignore — never commit it.

# Production (docker-compose.prod.yml + Caddy TLS)
DOMAIN={{ domain }}

# T-Invest API token (read-only is sufficient)
TINKOFF_TOKEN={{ tinkoff_token }}

# Trading tokens (only for TRADING mode)
T_TRADING_TOKEN_SANDBOX={{ t_trading_token_sandbox }}
T_TRADING_TOKEN_PRODUCTION={{ t_trading_token_production }}

# Scoring defaults
KEY_RATE={{ key_rate }}
TAX_RATE={{ tax_rate }}
MAX_DAYS={{ max_days }}
MIN_VOLUME_RUB={{ min_volume_rub }}

# Database (SQLite default; use Postgres in production)
# DATABASE_URL=sqlite+aiosqlite:///./cache/bond_monitor.db
# DATABASE_URL=postgresql+asyncpg://bondmonitor:bondmonitor@db:5432/bondmonitor

# Optional cache directory override
# CACHE_DIR=./cache

# API logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL={{ log_level }}

# Auth (Telegram Login Widget + JWT whitelist)
# AUTH_DISABLED=true disables auth for local dev/tests
AUTH_DISABLED={{ auth_disabled }}
AUTH_SECRET={{ auth_secret }}
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_BOT_USERNAME={{ telegram_bot_username }}
ALLOWED_TELEGRAM_IDS={{ allowed_telegram_ids }}
