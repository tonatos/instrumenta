# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.

# T-Invest API token (read-only is sufficient)
# Obtain at: https://www.tbank.ru/invest/settings/api/
# Without this token the app works with MOEX ISS data only (no risk flags, no coupon charts)
TINKOFF_TOKEN=

# Current ЦБ key rate (% per annum). Used as risk-free benchmark for scoring.
# Default: 14.5 (actual value as of May 2026)
KEY_RATE=14.5

# Personal income tax rate (% per annum). Applied to YTM, coupons and price gains.
# Russian scale: 13% up to 2.4M RUB/year tax base, 15/18/20/22% above progressively.
# Default: 13
TAX_RATE=13

# Maximum days to maturity / put-offer date included in the screener
# Default: 120 (≈ 4 months)
MAX_DAYS=120

# Minimum daily RUB trading volume on MOEX to consider a bond liquid
# Default: 500000 (500 000 ₽)
MIN_VOLUME_RUB=500000
