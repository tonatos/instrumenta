# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.

# T-Invest API token for bond enrich / screener (system-wide, read-only is enough)
TINKOFF_TOKEN=

# Trading tokens — LOCAL / AUTH_DISABLED only (fallback when user has no DB credentials).
# In multi-tenant prod users store encrypted tokens via /account (BROKER_KEK required).
# T_TRADING_TOKEN_SANDBOX=
# T_TRADING_TOKEN_PRODUCTION=

# Master key for envelope-encrypting per-user broker tokens (32 bytes base64/hex, or any secret).
# Required when AUTH_DISABLED=false. Keep separately from DB backups.
BROKER_KEK=

# Scoring defaults
KEY_RATE=14.5
TAX_RATE=13
MAX_DAYS=120
MIN_VOLUME_RUB=500000

# Database (SQLite default; use Postgres in production)
# DATABASE_URL=sqlite+aiosqlite:///./cache/bond_monitor.db
# DATABASE_URL=postgresql+asyncpg://bondmonitor:bondmonitor@db:5432/bondmonitor

# Optional cache directory override
# CACHE_DIR=./cache

# API logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Auth (Telegram OIDC + JWT)
# AUTH_DISABLED=true disables OIDC for local/e2e; middleware injects DEV_TELEGRAM_ID as owner.
AUTH_DISABLED=false
AUTH_SECRET=change-me-to-a-long-random-string
PUBLIC_APP_URL=http://127.0.0.1:5173
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
# Must match BotFather → Bot Settings → Web Login callback URL exactly
TELEGRAM_OIDC_REDIRECT_URI=http://127.0.0.1:5173/api/v1/auth/telegram/callback
# Optional allowlist (CSV). Empty = any Telegram user may sign in (SaaS open mode).
ALLOWED_TELEGRAM_IDS=
# Synthetic owner when AUTH_DISABLED=true
DEV_TELEGRAM_ID=1
# Backfill owner for portfolios/favorites created before multi-tenant migration
# TENANT_BACKFILL_TELEGRAM_ID=

# Production (docker-compose.prod.yml + Caddy TLS)
# DOMAIN=bond.example.com

# Notifier worker + Redis bus
# REDIS_URL=redis://redis:6379/0
# NOTIFIER_SCAN_INTERVAL_SEC=3600
# TELEGRAM_BOT_TOKEN=
# Legacy fallback chat if portfolio owner chat is unknown; prefer owner telegram_id
# TELEGRAM_NOTIFY_USER_ID=139693774
# NOTIFIER_LEDGER_PATH=./cache/notifier_ledger.db

# Local dev: inject fake alert data during notifier scan (never enable in production)
# NOTIFICATIONS_DEV=true
